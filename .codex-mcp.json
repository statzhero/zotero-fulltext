{
  "mcpServers": {
    "zotero": {
      "command": "uvx",
      "args": ["zotero-fulltext"],
      "env": {
        "ZOTERO_LIBRARY_TYPE": "${ZOTERO_LIBRARY_TYPE:-user}",
        "ZOTERO_LIBRARY_ID": "${ZOTERO_LIBRARY_ID:-0}",
        "ZOTERO_API_BASE_URL": "${ZOTERO_API_BASE_URL:-http://127.0.0.1:23119/api}",
        "ZOTERO_API_KEY": "${ZOTERO_API_KEY:-}",
        "ZOTERO_CACHE_DIR": "${ZOTERO_CACHE_DIR:-~/.cache/zotero-fulltext}"
      }
    }
  }
}
